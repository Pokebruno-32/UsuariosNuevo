@model ML.Usuario

<div class="modal fade" id="usuarioModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Form", "Usuario", FormMethod.Post, new { id = "usuarioForm" }))
            {
                <div class="modal-header">
                    <h5 class="modal-title">Usuario</h5>
                </div>
                <div class="modal-body">
                    @Html.HiddenFor(m => m.IdUsuario)

                    <div class="form-group">
                        @Html.LabelFor(m => m.NombreCompleto, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control", required = "required", placeholder = "Nombre Completo" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.NombreUsuario, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.NombreUsuario, new { @class = "form-control", required = "required", placeholder = "Nombre de Usuario" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Contraseña" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Correo, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", required = "required", placeholder = "Correo", type = "email" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Estatus, new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.Estatus,
                                 new SelectList(new[] { "Activo", "Inactivo" }, Model.Estatus),
                                 "-- Selecciona Estatus --",
                                 new { @class = "form-control", required = "required" })
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>
