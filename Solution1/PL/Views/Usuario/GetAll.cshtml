@model ML.Result
@{
    ViewBag.Title = "GetAll";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row mb-3">
        <div class="col-md-12">
            <button class="btn btn-success" onclick="openModal(0)">+</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            @if (Model.Objects != null && Model.Objects.Count > 0)
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Editar</th>
                            <th>IdUsuario</th>
                            <th>Nombre Completo</th>
                            <th>Nombre Usuario</th>
                            <th>Password</th>
                            <th>Correo</th>
                            <th>Estatus</th>
                            <th>Fecha Alta</th>
                            <th>Fecha Modificación</th>
                            <th>Eliminar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ML.Usuario usuario in Model.Objects)
                        {
                            <tr>
                                <td>
                                    <button class="btn btn-warning" onclick="openModal(@usuario.IdUsuario)">Editar</button>
                                </td>
                                <td>@usuario.IdUsuario</td>
                                <td>@usuario.NombreCompleto</td>
                                <td>@usuario.NombreUsuario</td>
                                <td>@(new string('*', usuario.Password?.Length ?? 0))</td>
                                <td>@usuario.Correo</td>
                                <td>@usuario.Estatus</td>
                                <td>@usuario.FechaAlta</td>
                                <td>@usuario.FechaModificacion</td>
                                <td>
                                    <button type="button" class="btn btn-danger" onclick="deleteUsuario(@usuario.IdUsuario)">
                                        Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-warning">
                    No existen registros en la tabla Usuario.
                </div>
            }
        </div>
    </div>
</div>

<div id="modalContainer"></div>


<script>
    function openModal(id) {
        $.get('/Usuario/Form/' + id, function (html) {
            $('#modalContainer').html(html);
            $('#usuarioModal').modal('show');

            $('#usuarioForm').submit(function (e) {
                e.preventDefault();
                $.post('/Usuario/Form', $(this).serialize(), function (response) {
                    if (response.success) {
                        alert("Usuario guardado correctamente");
                        $('#usuarioModal').modal('hide');
                        location.reload();
                    } else {
                        alert("Error: " + response.message);
                    }
                });
            });
        });
    }

    function deleteUsuario(id) {
        if (confirm("¿Seguro que deseas eliminar este usuario?")) {
            $.post('/Usuario/Delete/' + id, function (response) {
                if (response.success) {
                    alert("Usuario eliminado correctamente");
                    location.reload();
                } else {
                    alert("Error: " + response.message);
                }
            });
        }
    }
</script>


